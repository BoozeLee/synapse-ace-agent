# ============================================
# Synapse-Ace Autonomous Agent Configuration
# ============================================

# --- REQUIRED FOR REAL MODE (to actually win bounty) ---

# OOBE Protocol API Key (get at https://www.oobeprotocol.ai)
OOBE_API_KEY=sk_your_oobe_api_key_here

# Solana wallet private key (base58 format)
# WARNING: Never commit this to git!
SOLANA_PRIVATE_KEY=your_wallet_private_key_base58_here

# AceDataCloud API token (get at https://platform.acedata.cloud)
ACEDATA_API_TOKEN=your_acedatacloud_api_token_here

# x402 payment network: 'solana' | 'base' | 'skale'
ACEDATA_X402_NETWORK=solana

# --- OPTIONAL ---

# Set to 'true' to run in SIMULATION MODE (no real keys needed)
# SIMULATION=false

# Solana network: 'mainnet-beta' | 'devnet' | 'localnet'
SOLANA_NETWORK=mainnet-beta

# Initial escrow deposit in lamports (default: 0.001 SOL = 1000000 lamports)
ESCROW_INITIAL_DEPOSIT=1000000

# Maximum workflow steps (safety limit)
MAX_WORKFLOW_STEPS=10

# Payment priority fee multiplier (1.0 = normal, 2.0 = high)
PAYMENT_PRIORITY_MULTIPLIER=1.5

# Logging
LOG_LEVEL=info
NODE_ENV=production

# Optional: Jupiter API key (for advanced DEX features)
# JUPITER_API_KEY=your_jupiter_api_key_here

# Optional: Custom facilitator URL (defaults to AceDataCloud's)
# FACILITATOR_URL=https://facilitator.acedata.cloud

